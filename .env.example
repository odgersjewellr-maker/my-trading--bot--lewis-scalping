# BitGet API credentials
# Get these from: BitGet account → API Management
# Withdrawals: OFF. IP whitelist: ON.
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here
BITGET_BASE_URL=https://api.bitget.com

# Trading mode: "spot" or "futures"
TRADE_MODE=spot

# Strategy: "nkb" (default, Neural Kernel Bands) or "turtle-soup"
# (Linda Raschke false-breakout reversal — fades a failed break of the prior
# N-bar high/low). Backtest it first:  node backtest-turtle-soup.js
STRATEGY=nkb

# ─── Turtle Soup knobs (only used when STRATEGY=turtle-soup) ───
TS_LOOKBACK=20          # prior high/low the breakout is measured against
TS_MIN_AGE_BARS=3       # the prior extreme must be at least this many bars old
TS_STOP_BUFFER=0        # extra fraction beyond the breakout extreme for the stop (0.001 = 0.1%)
TS_REWARD_RISK=2        # take-profit distance as a multiple of the stop distance
TS_MAX_HOLD_BARS=4      # time-stop: exit if neither stop nor target hits within this many bars
TS_ALLOW_LONG=true      # take long (false-breakdown) setups
TS_ALLOW_SHORT=true     # take short (false-breakout) setups — needs TRADE_MODE=futures

# ─── Regime adaptation (only used when STRATEGY=turtle-soup) ───
# Tunes Turtle Soup to the market: a long fade is "buy the dip" (good in a bull),
# a short fade is "sell the rip" (good in a bear). Fading with the trend is what
# turns this strategy from losing to profitable. Off by default.
REGIME_ON=false             # true = adapt direction/size/hold to bull/bear/flat
REGIME_TREND_LEN=50         # SMA length that defines the trend
REGIME_SLOPE_LEN=10         # bars back to measure SMA slope
REGIME_BAND_PCT=0.5         # % band around the SMA that still counts as "flat"
REGIME_BULL_LONG=true       # bull regime: favour longs (buy the dip)
REGIME_BULL_SHORT=false     #              don't fade a strong uptrend
REGIME_BEAR_LONG=false      # bear regime: don't fight a downtrend
REGIME_BEAR_SHORT=true      #              favour shorts (sell the rip)
REGIME_FLAT_LONG=true       # flat/range: longs...
REGIME_FLAT_SHORT=false     #             (shorts in flat lost in testing — off)
REGIME_FLAT_HOLD_MULT=0.5   # flat: small time in market (× the base time-stop)
REGIME_FLAT_SIZE_MULT=1.0   # flat: size multiplier (1.0 = neutral; sizing up flat didn't help)
REGIME_TREND_SIZE_MULT=1.0  # bull/bear: size multiplier
REGIME_TREND_HOLD_MULT=1.0  # bull/bear: time-in-market multiplier

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=1000

# Trade limits — these are your guardrails
MAX_TRADE_SIZE_USD=100        # No single trade can exceed this value
MAX_TRADES_PER_DAY=3          # Bot stops executing after this many trades in a calendar day. 0 = no daily limit

# Symbol and timeframe (must match the cron schedule in .github/workflows/run-bot.yml
# so the bot checks for a new entry roughly as often as a new candle closes)
SYMBOL=BTCUSDT
TIMEFRAME=15m

# Set to "true" to run in paper trading mode (logs decisions but never places real orders)
PAPER_TRADING=true

# Stop loss — sent to BitGet as the preset stop-loss price on the entry order
# itself, so the exchange enforces it directly on real trades.
STOP_LOSS_PCT=0.3      # % away from entry price
ATR_PERIOD=14           # Candles used for the informational ATR display in logs
