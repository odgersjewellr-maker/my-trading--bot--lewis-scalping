# BitGet API credentials
# Get these from: BitGet account → API Management
# Withdrawals: OFF. IP whitelist: ON.
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here
BITGET_BASE_URL=https://api.bitget.com

# Trading mode: "spot" or "futures"
TRADE_MODE=spot

# Portfolio value — used to calculate position size
PORTFOLIO_VALUE_USD=1000

# Trade limits — these are your guardrails
MAX_TRADE_SIZE_USD=100        # No single trade can exceed this value
MAX_TRADES_PER_DAY=3          # Bot stops executing after this many trades in a calendar day. 0 = no daily limit

# Symbol and timeframe
SYMBOL=BTCUSDT
TIMEFRAME=4H

# Set to "true" to run in paper trading mode (logs decisions but never places real orders)
PAPER_TRADING=true

# Exit logic — applied to every open position before any new entry is considered
STOP_LOSS_PCT=0.3      # Fixed stop loss, % away from entry price (floor — never tighter than this)
TRAILING_STOP_PCT=0.5  # Trailing stop, % away from the best price reached since entry (floor)

# Volatility-adjusted stops — widen the stop/trailing distance in choppy
# markets so normal noise doesn't trigger a premature exit. The bot uses
# whichever is WIDER: the fixed % above, or ATR x multiplier below.
ATR_PERIOD=14           # Candles used to calculate Average True Range
ATR_STOP_MULT=1.5       # Stop loss distance = ATR x this multiplier
ATR_TRAILING_MULT=2.5   # Trailing stop distance = ATR x this multiplier
