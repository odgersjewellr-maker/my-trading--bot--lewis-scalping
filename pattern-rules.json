{
  "description": "If-this-then-that pattern trading rules. Each rule: IF all listed conditions fire (and none of the veto conditions do) on a closed candle, THEN take the action. Rules are checked top to bottom; the first match wins. Condition ids come from patterns.js.",

  "settings": {
    "fee_pct_per_side": 0.1,
    "one_position_at_a_time": true
  },

  "rules": [
    {
      "name": "Three white soldiers",
      "enabled": true,
      "if": { "all": ["three_white_soldiers"], "none": [] },
      "then": { "action": "long", "hold_candles": 3, "stop_pct": 4 }
    },
    {
      "name": "Trend breakout",
      "enabled": true,
      "if": {
        "all": ["above_sma50", "close_above_prev_high"],
        "none": ["bearish_engulfing", "evening_star", "shooting_star", "dark_cloud_cover"]
      },
      "then": { "action": "long", "hold_candles": 3, "stop_pct": 4 }
    },
    {
      "name": "Inside bar in uptrend",
      "enabled": true,
      "if": { "all": ["above_sma50", "inside_bar"], "none": ["three_black_crows"] },
      "then": { "action": "long", "hold_candles": 3, "stop_pct": 4 }
    },
    {
      "name": "Morning star in uptrend",
      "enabled": true,
      "if": { "all": ["above_sma50", "morning_star"], "none": [] },
      "then": { "action": "long", "hold_candles": 3, "stop_pct": 4 }
    },
    {
      "name": "Breakdown short (example — OFF: shorting bear patterns lost money on BTC daily 2018-2026)",
      "enabled": false,
      "if": { "all": ["below_sma50", "close_below_prev_low"], "none": [] },
      "then": { "action": "short", "hold_candles": 3, "stop_pct": 4 }
    }
  ]
}
