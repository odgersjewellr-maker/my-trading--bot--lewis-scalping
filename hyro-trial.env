# HyroTrader FREE TRIAL run configuration (2026-07-16) — NO secrets in here;
# credentials live in hyrotrader/.env (gitignored), passed as a second
# --env-file by run-hyro-trial.ps1.
#
# Mirrors the SOL-PROP paper book (15m, 0.5% risk, markov gate) with
# HyroTrader 1-Step guard geometry (15% target / 4% daily / 6% max DD,
# 00:00 UTC reset). Trial = live-fire rehearsal of the challenge config.
BROKER=hyrotrader
PAPER_TRADING=false
TRADE_MODE=futures
LEVERAGE=1
TRADE_SIZE_PCT=80
SYMBOL=SOLUSDT
INSTANCE_ID=SOLUSDT-HYRO
TIMEFRAME=15m
NKB_KERNEL=gaussian
NKB_BAND_MULT=3.0
NKB_BANDWIDTH=6.0
NKB_ATR_STOP_MULT=1.0
REGIME_GATE=markov
MAX_TRADES_PER_DAY=0
MAX_TRADE_SIZE_USD=10000
PORTFOLIO_VALUE_USD=5000
RISK_PCT=0.5
PROP_MODE=true
PROP_RISK_PCT=0.5
PROP_TARGET_PCT=15
PROP_MAX_DD_PCT=6
PROP_DD_GUARD=0.9
PROP_DAILY_LIMIT_PCT=4
PROP_DAILY_GUARD=0.7
PROP_LEV_CAP=2
PROP_SWAP_RATE=0
PROP_DAY_RESET_MIN=0
